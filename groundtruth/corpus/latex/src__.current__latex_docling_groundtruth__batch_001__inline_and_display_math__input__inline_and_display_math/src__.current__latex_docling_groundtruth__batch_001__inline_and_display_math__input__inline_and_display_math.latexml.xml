    <title><tag close=" ">1</tag>Math</title>
    <para xml:id="src__.current__latex_docling_groundtruth__batch_001__inline_and_display_math__input__inline_and_display_math.S1.p1">
      <p>Inline <Math mode="inline" tex="x+y" text="x + y" xml:id="src__.current__latex_docling_groundtruth__batch_001__inline_and_display_math__input__inline_and_display_math.S1.p1.m1">
          <XMath>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok font="italic" role="UNKNOWN">y</XMTok>
            </XMApp>
          </XMath>
        </Math> and</p>
      <equation xml:id="src__.current__latex_docling_groundtruth__batch_001__inline_and_display_math__input__inline_and_display_math.S1.Ex1">
        <Math mode="display" tex="x^{2}+y^{2}=z^{2}" text="x ^ 2 + y ^ 2 = z ^ 2" xml:id="src__.current__latex_docling_groundtruth__batch_001__inline_and_display_math__input__inline_and_display_math.S1.Ex1.m1">
          <XMath>
            <XMApp>
              <XMTok meaning="equals" role="RELOP">=</XMTok>
              <XMApp>
                <XMTok meaning="plus" role="ADDOP">+</XMTok>
                <XMApp>
                  <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                  <XMTok font="italic" role="UNKNOWN">x</XMTok>
                  <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                </XMApp>
                <XMApp>
                  <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                  <XMTok font="italic" role="UNKNOWN">y</XMTok>
                  <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                </XMApp>
              </XMApp>
              <XMApp>
                <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                <XMTok font="italic" role="UNKNOWN">z</XMTok>
                <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
            </XMApp>
          </XMath>
        </Math>
      </equation>
      <p>display.</p>
    </para>
