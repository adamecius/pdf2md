#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

ENV_FLAVOR="conda"
ENV_NAME="pdf2md-deepseek"
MODEL_ID="deepseek-ai/DeepSeek-OCR-2"
MODELS_DIR=".local_models/deepseek"
ALLOW_DOWNLOAD=0
SKIP_GPU_STACK=0

usage() {
  cat <<USAGE
Usage:
  ./setup.sh [options]

End-to-end setup for backend/deepseek based on README.md.

Options:
  --envflavor <conda|venv>   Environment manager (default: conda)
  --envname <name_or_path>   Env name/path (default: pdf2md-deepseek)
  --model-id <id>            Model id for first-time download test
  --models-dir <path>        Base models directory (default: .local_models/deepseek)
  --allow-download           Perform explicit first-time model download check
  --skip-gpu-stack           Skip Torch/vLLM/flash-attn installation
  -h, --help                 Show this help
USAGE
}

log() { printf '\n[deepseek-setup] %s\n' "$1"; }
fail() { printf '\n[deepseek-setup] ERROR: %s\n' "$1" >&2; exit 1; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    --envflavor) ENV_FLAVOR="${2:-}"; shift 2 ;;
    --envname) ENV_NAME="${2:-}"; shift 2 ;;
    --model-id) MODEL_ID="${2:-}"; shift 2 ;;
    --models-dir) MODELS_DIR="${2:-}"; shift 2 ;;
    --allow-download) ALLOW_DOWNLOAD=1; shift ;;
    --skip-gpu-stack) SKIP_GPU_STACK=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) fail "Unknown argument: $1" ;;
  esac
done

if [[ "$ENV_FLAVOR" != "conda" && "$ENV_FLAVOR" != "venv" ]]; then
  fail "--envflavor must be conda or venv"
fi

if [[ "$ENV_FLAVOR" == "venv" && "$ENV_NAME" == "pdf2md-deepseek" ]]; then
  ENV_NAME=".venv-deepseek"
fi

command -v python >/dev/null 2>&1 || fail "python is required"
cd "$SCRIPT_DIR"

log "Creating/updating environment using setup_env.py"
#python setup_env.py --manager "$ENV_FLAVOR" --env-name "$ENV_NAME"

if [[ "$ENV_FLAVOR" == "conda" ]]; then
  command -v conda >/dev/null 2>&1 || fail "conda is required for conda mode"
  # shellcheck disable=SC1091
  source "$(conda info --base)/etc/profile.d/conda.sh"
  conda activate "$ENV_NAME"
else
  # shellcheck disable=SC1091
  source "$ENV_NAME/bin/activate"
fi

log "Environment active: $ENV_NAME"

if [[ $SKIP_GPU_STACK -eq 0 ]]; then
  log "Installing Torch CUDA 11.8 wheels"
  python -m pip install \
    torch==2.6.0 \
    torchvision==0.21.0 \
    torchaudio==2.6.0 \
    --index-url https://download.pytorch.org/whl/cu118

  log "Configuring CUDA toolchain exports for this shell"
  if [[ -n "${CONDA_PREFIX:-}" ]]; then
    export CUDA_HOME="$CONDA_PREFIX"
  elif [[ -z "${CUDA_HOME:-}" && -d "/usr/local/cuda-11.8" ]]; then
    export CUDA_HOME="/usr/local/cuda-11.8"
  fi
  if [[ -n "${CUDA_HOME:-}" ]]; then
    export PATH="$CUDA_HOME/bin:$PATH"
    export LD_LIBRARY_PATH="$CUDA_HOME/lib:$CUDA_HOME/lib64:${LD_LIBRARY_PATH:-}"
  fi

  if [[ -n "${CONDA_PREFIX:-}" ]]; then
    mkdir -p "$CONDA_PREFIX/etc/conda/activate.d"
    cat > "$CONDA_PREFIX/etc/conda/activate.d/pdf2md-deepseek-cuda.sh" <<'ACTIVATE'
export CUDA_HOME="$CONDA_PREFIX"
export PATH="$CUDA_HOME/bin:$PATH"
export LD_LIBRARY_PATH="$CUDA_HOME/lib:$CUDA_HOME/lib64:${LD_LIBRARY_PATH:-}"
ACTIVATE
  fi

  log "Installing vLLM (CUDA wheel version from README guidance)"
  pip install vllm-0.8.5+cu118-cp38-abi3-manylinux1_x86_64.whl

  log "installing requirements"
  pip install -r requirements.txt
 
  log "Installing flash-attn"
  python -m pip install flash-attn==2.7.3 --no-build-isolation 
else
  log "Skipping GPU stack install as requested"
fi

log "Pinning NumPy for compatibility"
python -m pip install "numpy==2.2.6"

log "Verifying runtime"
python - <<'PY'
import os
import importlib
import numpy
print('numpy:', numpy.__version__)
for mod in ['torch','vllm','flash_attn']:
    try:
        m = importlib.import_module(mod)
        print(f'{mod}:', getattr(m, '__version__', 'imported'))
    except Exception as exc:
        print(f'{mod}: import failed ({exc})')
print('CUDA_HOME:', os.environ.get('CUDA_HOME'))
PY

if [[ $ALLOW_DOWNLOAD -eq 1 ]]; then
  log "Running explicit first-time model download test"
  tmp_pdf="${SCRIPT_DIR}/.setup-smoke-test.pdf"
  printf '%s\n' '%PDF-1.1' '1 0 obj<<>>endobj' 'trailer<<>>' '%%EOF' > "$tmp_pdf"
  python "$SCRIPT_DIR/pdf2md_deepseek.py" \
    -i "$tmp_pdf" \
    --model-id "$MODEL_ID" \
    --models-dir "$MODELS_DIR" \
    --allow-download || true
  rm -f "$tmp_pdf"
fi

cat <<DONE

[deepseek-setup] Done.

Activate later:
  conda activate $ENV_NAME
  # or
  source $ENV_NAME/bin/activate

Example run with explicit first download:
  python backend/deepseek/pdf2md_deepseek.py -i test.pdf \
    --model-id $MODEL_ID \
    --models-dir $MODELS_DIR \
    --allow-download
DONE
