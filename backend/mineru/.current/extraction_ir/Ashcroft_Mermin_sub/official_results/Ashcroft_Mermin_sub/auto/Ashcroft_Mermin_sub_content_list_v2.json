    [
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/b0af64fa6b1f8eadd057f8fb894fc3af64c79de363eab163889b6784ca99e6de.jpg"
                },
                "image_caption": [
                    {
                        "type": "text",
